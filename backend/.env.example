FLASK_ENV=development
FLASK_DEBUG=1
PORT=5000

# MongoDB Atlas connection string.
# Example: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DATABASE=ai_business_competition_analyzer
LOCAL_DATA_PATH=

# Google AI Studio Gemini API key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Comma-separated frontend origins allowed by Flask-CORS.
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,https://your-vercel-domain.vercel.app
